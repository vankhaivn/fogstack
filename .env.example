# fogstack local-only example values.
# Copy to .env only if you want local shell defaults; never put real credentials here.

AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
FOGSTACK_PROFILE=minimal

POSTGRES_USER=fogstack
POSTGRES_PASSWORD=test
POSTGRES_DB=appdb
