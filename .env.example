# fogstack local-only example values.
# Copy this file to .env only for local defaults; never put real credentials here.

# Default profile for your own shell commands.
FOGSTACK_PROFILE=minimal

# Set to 1 only when developing fogstack itself.
FOGSTACK_DEV=0

# Test hook for doctor validation; leave empty for normal use.
FOGSTACK_DOCTOR_HIDE_COMMANDS=

# Local cluster name.
CLUSTER_NAME=fogstack

# Local Kubernetes context name.
KUBE_CONTEXT=kind-fogstack

# Local registry container name.
REGISTRY_NAME=fogstack-registry

# Local registry host reachable from the host.
REGISTRY_HOST=localhost

# Local registry host port.
REGISTRY_PORT=5001

# Local Postgres host reachable from the host.
POSTGRES_HOST=localhost

# Local Postgres host port.
POSTGRES_PORT=5432

# Local Postgres database user.
POSTGRES_USER=fogstack

# Local Postgres database password.
POSTGRES_PASSWORD=test

# Local Postgres database name.
POSTGRES_DB=appdb

# Local Redis host reachable from the host.
REDIS_HOST=localhost

# Local Redis host port.
REDIS_PORT=6379

# Local Redis database number.
REDIS_DB=0

# Local AWS-compatible API endpoint for the full profile.
AWS_ENDPOINT_URL=http://localhost:4566

# Fake local AWS access key.
AWS_ACCESS_KEY_ID=test

# Fake local AWS secret key.
AWS_SECRET_ACCESS_KEY=test

# Fake local AWS region.
AWS_DEFAULT_REGION=us-east-1

# Local OpenSearch endpoint for the full profile.
OPENSEARCH_URL=http://localhost:9200

# Local OpenSearch Dashboards endpoint for the full profile.
DASHBOARDS_URL=http://localhost:5601

# Optional cloud-provider-kind PID file path.
FOGSTACK_CPK_PID_FILE=/tmp/fogstack-cpk.pid

# Optional cloud-provider-kind log file path.
FOGSTACK_CPK_LOG_FILE=/tmp/fogstack-cpk.log
